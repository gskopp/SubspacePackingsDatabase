          RowBox[{
           RowBox[{"d", " ", 
            RowBox[{"(", 
             RowBox[{"i", "-", "1"}], ")"}]}], "+", "j"}], "]"}], "]"}], "+", 
        
        RowBox[{
         RowBox[{"gos", "[", 
