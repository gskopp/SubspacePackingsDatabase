    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"normalizeSO", "[", "Phi_", "]"}], ":=", 
     RowBox[{
      RowBox[{"normalizeAO", "[", 
       RowBox[{"Phi", "\[ConjugateTranspose]"}], "]"}], 
      "\[ConjugateTranspose]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Gram", " ", "matrix", " ", "from", " ", "vector", " ", "list"}], 
