   RowBox[{"(*", " ", 
    RowBox[{
    "currently", " ", "implemented", " ", "when", " ", "all", " ", "triple", " ",
      "products", " ", "are", " ", "nonzero"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SOfromTP", "[", 
      RowBox[{"T_", ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"SOfromGM", "[", 
      RowBox[{
       RowBox[{"GMfromTP", "[", "T", "]"}], ",", "tolerence"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Faithful", " ", "matrix", " ", "plot", " ", "for", " ", "synthesis", " ",
      "operator", " ", "or", " ", "Gram", " ", "matrix"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FrameVisualize", "[", "M_", "]"}], ":=", 
     RowBox[{"MatrixPlot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Hue", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Arg", "[", "#", "]"}], "+", "Pi"}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"2", "Pi"}], ")"}]}], ",", 
             RowBox[{"Abs", "[", "#", "]"}]}], "]"}], "&"}], "/@", "#"}], 
         "&"}], "/@", "M"}], ",", 
       RowBox[{"Frame", "->", "False"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
