   RowBox[{
    RowBox[{
     RowBox[{"GMfromSO", "[", "Phi_", "]"}], ":=", 
     RowBox[{
      RowBox[{"Phi", "\[ConjugateTranspose]"}], ".", "Phi"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Triple", " ", "product", " ", "tensor", " ", "from", " ", "Gram", " ", 
     "matrix"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"TPfromGM", "[", "G_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "n", "}"}], ",", 
       RowBox[{
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "G", "]"}]}], ";", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"G", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "j"}], "]"}], "]"}], 
           RowBox[{"G", "[", 
            RowBox[{"[", 
             RowBox[{"j", ",", "k"}], "]"}], "]"}], 
           RowBox[{"G", "[", 
            RowBox[{"[", 
             RowBox[{"k", ",", "i"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Triple", " ", "product", " ", "tensor", " ", "from", " ", "vector", " ", 
     "list"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"TPfromSO", "[", "Phi_", "]"}], ":=", 
     RowBox[{"TPfromGM", "[", 
      RowBox[{"GMfromSO", "[", "Phi", "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Vector", " ", "list", " ", "from", " ", "Gram", " ", "matrix"}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"SOfromGM", "[", 
      RowBox[{"G_", ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"d", ",", "U", ",", "\[CapitalLambda]", ",", "V"}], "}"}], ",", 
       RowBox[{
        RowBox[{"d", "=", 
         RowBox[{"MatrixRank", "[", 
          RowBox[{"G", ",", 
           RowBox[{"Tolerance", "->", "tolerence"}]}], "]"}]}], ";", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"U", ",", "\[CapitalLambda]", ",", "V"}], "}"}], "=", 
         RowBox[{"SingularValueDecomposition", "[", 
          RowBox[{"G", ",", 
           RowBox[{"UpTo", "[", "d", "]"}]}], "]"}]}], ";", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"U", ".", 
           RowBox[{"Sqrt", "[", "\[CapitalLambda]", "]"}]}], ")"}], 
         "\[ConjugateTranspose]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Gram", " ", "matrix", " ", "from", " ", "triple", " ", "product", " ", 
     "tensor"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "currently", " ", "implemented", " ", "when", " ", "all", " ", "triple", " ",
      "products", " ", "are", " ", "nonzero"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GMfromTP", "[", "T_", "]"}], ":=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"T", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "j", ",", "1"}], "]"}], "]"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"T", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "1", ",", "1"}], "]"}], "]"}], 
           RowBox[{"T", "[", 
            RowBox[{"[", 
             RowBox[{"j", ",", "1", ",", "1"}], "]"}], "]"}]}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"1", "/", "2"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"Length", "[", "T", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", 
         RowBox[{"Length", "[", "T", "]"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Vector", " ", "list", " ", "from", " ", "triple", " ", "product", " ", 
