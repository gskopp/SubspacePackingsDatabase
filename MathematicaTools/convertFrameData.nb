   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Normalized", " ", 
     RowBox[{"(", "unit", ")"}], " ", "analysis", " ", "operator", " ", 
     "from", " ", "unnormalized", " ", "analysis", " ", "operator"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"normalizeAO", "[", "V_", "]"}], ":=", 
     RowBox[{"Normalize", "/@", "V"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Normalized", " ", 
     RowBox[{"(", "unit", ")"}], " ", "synthesis", " ", "operator", " ", 
