              RowBox[{"i", "-", "1"}], ")"}]}], "+", "j"}], "]"}], "]"}], 
         "I"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "d"}], "}"}], ",", 
