Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Tests", " ", "\"\<moment equivalence\>\"", " ", "of", " ", "Phi1_", " ", 
     "and", " ", "Phi2_", " ", "up", " ", "to", " ", "threshold"}], ",", " ", 
    
    RowBox[{"that", " ", "is"}], ",", " ", 
    RowBox[{
    "whether", " ", "the", " ", "first", " ", "few", " ", "moments", " ", 
     "are", " ", "equal"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"At", " ", "threshold_"}], " ", "=", " ", 
     RowBox[{"n", "^", "3"}]}], ",", " ", 
    RowBox[{
    "moment", " ", "equivalence", " ", "is", " ", "the", " ", "same", " ", 
     "as", " ", "equivalence", " ", "of", " ", "the", " ", "set", " ", "of", " ",
      "triple", " ", "products", " ", "as", " ", "multisets"}]}], " ", "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "is", " ", "strictly", " ", "weaker", " ", "than", " ", 
    "projective", " ", "permutation", " ", "unitary", " ", "equivalence"}], 
   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"dirtyFrameEquiv", "[", 
      RowBox[{"Phi1_", ",", "Phi2_", ",", 
       RowBox[{"threshold_", ":", "10"}], ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"moments1", ",", "moments2"}], "}"}], ",", 
       RowBox[{
        RowBox[{"moments1", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"momentfromSO", "[", 
            RowBox[{"Phi1", ",", "m"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"m", ",", "1", ",", "threshold"}], "}"}]}], "]"}]}], ";", 
        
        RowBox[{"moments2", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"momentfromSO", "[", 
            RowBox[{"Phi2", ",", "m"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"m", ",", "1", ",", "threshold"}], "}"}]}], "]"}]}], ";", 
        
        RowBox[{
         RowBox[{"Norm", "[", 
          RowBox[{"moments1", "-", "moments2"}], "]"}], "<", 
         "tolerence"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Tests", " ", "equivalence", " ", "of", " ", "tests_", " ", "random", " ",
      "basic", " ", "S_n", " ", "invariants", " ", "of", " ", "degree", " ", 
     "degree_", " ", "on", " ", "an", " ", "index", " ", "set", " ", "of", " ",
      "size", " ", "breadth_"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "For", " ", "sufficiently", " ", "many", " ", "tests", " ", "in", " ", 
      "sufficiently", " ", "large", " ", "degree"}], ",", " ", 
     RowBox[{
     "this", " ", "is", " ", "equivalent", " ", "to", " ", "projective", " ", 
      "permutation", " ", "unitary", " ", "equivalence", " ", "by", " ", 
      RowBox[{"Hilbert", "'"}], "s", " ", "basis", " ", "theorem"}]}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"However", ",", " ", 
     RowBox[{
     "rigorous", " ", "bounds", " ", "are", " ", "not", " ", "known", " ", 
      "here"}]}], " ", "*)"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"randomInvariantFrameEquiv", "[", 
      RowBox[{"Phi1_", ",", "Phi2_", ",", 
       RowBox[{"breadth_", ":", "3"}], ",", 
       RowBox[{"degree_", ":", "12"}], ",", 
       RowBox[{"tests_", ":", "10"}], ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"And", "@@", 
      RowBox[{"ParallelTable", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{
             RowBox[{"generalSnInvariantfromSO", "[", 
              RowBox[{"Phi1", ",", "#"}], "]"}], "-", 
             RowBox[{"generalSnInvariantfromSO", "[", 
              RowBox[{"Phi2", ",", "#"}], "]"}]}], "]"}], "&"}], "[", 
          RowBox[{"RandomInteger", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"1", ",", "breadth"}], "}"}], ",", "degree"}], "]"}], 
          "]"}], "<", "tolerence"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "tests"}], "}"}]}], "]"}]}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9831051532414293`*^9, 3.9831055003320208`*^9}, {
