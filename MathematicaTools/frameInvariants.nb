Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Created", " ", "by", " ", "Gene", " ", "Kopp"}], ",", " ", 
    RowBox[{"Mar", " ", "2026"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Functions", " ", "to", " ", "compute", " ", "invariants", " ", "of", " ", 
    "frames"}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.98286826304141*^9, 
  3.982868301775188*^9}},ExpressionUUID->"474c95d0-477e-40c3-87aa-\
c668eb635352"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "List", " ", "of", " ", "distict", " ", "triple", " ", "products"}], ",", 
    " ", 
    RowBox[{"including", " ", "degenerate", " ", "ones"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"distinctTPfromSO", "[", 
      RowBox[{"Phi_", ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"DeleteDuplicates", "[", 
      RowBox[{
       RowBox[{"Chop", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{"TPfromSO", "[", "Phi", "]"}], "]"}], "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"#1", "-", "#2"}], "]"}], "<", "tolerence"}], "&"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Number", " ", "of", " ", "distict", " ", "triple", " ", "products"}], 
     ",", " ", 
     RowBox[{"including", " ", "degenerate", " ", "ones"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"numberTPfromSO", "[", 
      RowBox[{"Phi_", ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"Length", "[", 
      RowBox[{"distinctTPfromSO", "[", 
       RowBox[{"Phi", ",", "tolerence"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Moments", " ", "[", 
     RowBox[{
     "sum", " ", "of", " ", "powers", " ", "of", " ", "triple", " ", 
      "products"}], "]"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"momentfromSO", "[", 
      RowBox[{"Phi_", ",", "m_"}], "]"}], ":=", 
     RowBox[{"Plus", "@@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"TPfromSO", "[", "Phi", "]"}], "]"}], "^", "m"}], ")"}]}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Nondiagonal", " ", 
     RowBox[{"moments", " ", "[", 
      RowBox[{
      "sum", " ", "of", " ", "powers", " ", "of", " ", "totally", " ", 
       "nondiagonal", " ", "triple", " ", "products"}], "]"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"momentndfromSO", "[", 
      RowBox[{"Phi_", ",", "m_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"T", ",", "n"}], "}"}], ",", 
       RowBox[{
        RowBox[{"T", "=", 
         RowBox[{"TPfromSO", "[", "Phi", "]"}]}], ";", 
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "T", "]"}]}], ";", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"i", "-", "j"}], ")"}], 
              RowBox[{"(", 
               RowBox[{"j", "-", "k"}], ")"}], 
              RowBox[{"(", 
               RowBox[{"k", "-", "i"}], ")"}]}], "==", "0"}], ",", "0", ",", 
            RowBox[{
             RowBox[{"T", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "j", ",", "k"}], "]"}], "]"}], "^", "m"}]}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Compute", " ", "a", " ", "general", " ", "m"}], "-", 
     RowBox[{
     "product", " ", "with", " ", "index", " ", "set", " ", "Indices_"}]}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"mproductfromGM", "[", 
      RowBox[{"G_", ",", "Indices_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"m", ",", "wrapIndices"}], "}"}], ",", 
       RowBox[{
        RowBox[{"m", "=", 
         RowBox[{"Length", "[", "Indices", "]"}]}], ";", 
        RowBox[{"wrapIndices", "=", 
         RowBox[{"Append", "[", 
          RowBox[{"Indices", ",", 
           RowBox[{"Indices", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", 
        RowBox[{"Product", "[", 
         RowBox[{
          RowBox[{"G", "[", 
           RowBox[{"[", 
            RowBox[{
             RowBox[{"wrapIndices", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", 
             RowBox[{"wrapIndices", "[", 
              RowBox[{"[", 
               RowBox[{"i", "+", "1"}], "]"}], "]"}]}], "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "m"}], "}"}]}], "]"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"mproductfromSO", "[", 
      RowBox[{"Phi_", ",", "Indices_"}], "]"}], ":=", 
     RowBox[{"mproductfromSO", "[", 
      RowBox[{
       RowBox[{"GMfromSO", "[", "Phi", "]"}], ",", "Indices"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Compute", " ", "the", " ", "sum", " ", "of", " ", "all", " ", "m"}], 
     "-", 
     RowBox[{
     "products", " ", "with", " ", "index", " ", "set", " ", "of", " ", 
      "shape", " ", "Indices_"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"For", " ", "example"}], ",", " ", 
     RowBox[{"the", " ", "index", " ", "set", " ", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "c", ",", "a", ",", "b", ",", "c"}], "}"}],
       " ", "yields", " ", "the", " ", "second", " ", "moment", " ", "of", 
      " ", "the", " ", "triple", " ", "products"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "I", " ", "think", " ", "these", " ", "generate", " ", "all", " ", 
      "S_n"}], "-", 
     RowBox[{"invariants", " ", "[", 
      RowBox[{
       RowBox[{"i", ".", "e", "."}], ",", " ", 
       RowBox[{
       "projective", " ", "permutation", " ", "unitary", " ", 
        "invariants"}]}], "]"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"generalSnInvariantfromGM", "[", 
      RowBox[{"G_", ",", "Indices_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"IndexSet", ",", "n", ",", "k"}], "}"}], ",", 
       RowBox[{
        RowBox[{"IndexSet", "=", 
         RowBox[{"DeleteDuplicates", "[", "Indices", "]"}]}], ";", 
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "G", "]"}]}], ";", 
        RowBox[{"k", "=", 
         RowBox[{"Length", "[", "IndexSet", "]"}]}], ";", 
        RowBox[{"Plus", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"mproductfromGM", "[", 
             RowBox[{"G", ",", "#"}], "]"}], "&"}], "/@", 
           RowBox[{"(", 
            RowBox[{"IndexSet", "/.", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"Thread", "[", 
                 RowBox[{"Indices", "->", "#"}], "]"}], "&"}], "/@", 
               RowBox[{"Tuples", "[", 
                RowBox[{
                 RowBox[{"Range", "[", "n", "]"}], ",", "k"}], "]"}]}], 
              ")"}]}], ")"}]}], ")"}]}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"generalSnInvariantfromSO", "[", 
      RowBox[{"Phi_", ",", "Indices_"}], "]"}], ":=", 
     RowBox[{"generalSnInvariantfromGM", "[", 
      RowBox[{
       RowBox[{"GMfromSO", "[", "Phi", "]"}], ",", "Indices"}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9828683075202723`*^9, 3.982868686488283*^9}, {
  3.984061031763249*^9, 3.984061059993718*^9}, {3.984061270811294*^9, 
