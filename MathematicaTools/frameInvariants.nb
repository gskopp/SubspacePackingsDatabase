c668eb635352"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "List", " ", "of", " ", "distict", " ", "triple", " ", "products"}], ",", 
    " ", 
    RowBox[{"including", " ", "degenerate", " ", "ones"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"distinctTPfromSO", "[", 
      RowBox[{"Phi_", ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"DeleteDuplicates", "[", 
      RowBox[{
       RowBox[{"Chop", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{"TPfromSO", "[", "Phi", "]"}], "]"}], "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"#1", "-", "#2"}], "]"}], "<", "tolerence"}], "&"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Number", " ", "of", " ", "distict", " ", "triple", " ", "products"}], ",",
      " ", 
     RowBox[{"including", " ", "degenerate", " ", "ones"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"numberTPfromSO", "[", 
      RowBox[{"Phi_", ",", 
       RowBox[{"tolerence_", ":", 
        RowBox[{"10", "^", 
         RowBox[{"(", 
          RowBox[{"-", "6"}], ")"}]}]}]}], "]"}], ":=", 
     RowBox[{"Length", "[", 
      RowBox[{"distinctTPfromSO", "[", 
       RowBox[{"Phi", ",", "tolerence"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Moments", " ", "[", 
     RowBox[{
     "sum", " ", "of", " ", "powers", " ", "of", " ", "triple", " ", 
      "products"}], "]"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"momentfromSO", "[", 
      RowBox[{"Phi_", ",", "m_"}], "]"}], ":=", 
     RowBox[{"Plus", "@@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"TPfromSO", "[", "Phi", "]"}], "]"}], "^", "m"}], ")"}]}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Nondiagonal", " ", 
     RowBox[{"moments", " ", "[", 
      RowBox[{
      "sum", " ", "of", " ", "powers", " ", "of", " ", "totally", " ", 
       "nondiagonal", " ", "triple", " ", "products"}], "]"}]}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"momentndfromSO", "[", 
      RowBox[{"Phi_", ",", "m_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"T", ",", "n"}], "}"}], ",", 
       RowBox[{
        RowBox[{"T", "=", 
         RowBox[{"TPfromSO", "[", "Phi", "]"}]}], ";", 
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "T", "]"}]}], ";", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"i", "-", "j"}], ")"}], 
              RowBox[{"(", 
               RowBox[{"j", "-", "k"}], ")"}], 
              RowBox[{"(", 
               RowBox[{"k", "-", "i"}], ")"}]}], "==", "0"}], ",", "0", ",", 
            RowBox[{
             RowBox[{"T", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "j", ",", "k"}], "]"}], "]"}], "^", "m"}]}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "1", ",", "n"}], "}"}]}], "]"}]}]}], "]"}]}], 
    ";"}]}]}]], "Input",
